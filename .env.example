# ============================================
# SABLONA PROMENNYCH PROSTREDI
# ============================================
# Zkopiruj tento soubor jako `.env` a vypln skutecnymi hodnotami.
# Soubor `.env` je v .gitignore a NIKDY se necommituje.

# Lokalni PostgreSQL databaze
DATABASE_URL="postgresql://uzivatel:heslo@localhost:5432/recepai"

# OpenAI API klic (pro skenovani dokladu navstev pres gpt-4o-mini)
OPENAI_API_KEY="sk-proj-..."

# ============================================
# PRIHLASOVACI UDAJE ZAMESTNANCU
# ============================================
# Heslo nebo PIN zmenis primo zde: uprav prislusny radek a uloz soubor.
# Pole jednoho zamestnance jsou pohromade pod sebou.
# Cislo (USER_1, USER_2, ...) jen oddeluje zamestnance, na poradi nezalezi.
# Dalsiho zamestnance pridas zkopirovanim bloku a zvysenim cisla (USER_2, USER_3, ...).

# --- 1. Vzorovy reditel (Reditel / CEO) ---
USER_1_USERNAME=admin
USER_1_PASSWORD=zmen-me
USER_1_PIN=0000
USER_1_ROLE=CEO
USER_1_DISPLAYNAME=Jmeno Prijmeni
USER_1_FIRSTNAME=Jmeno
USER_1_LASTNAME=Prijmeni
USER_1_EMPLOYEENUMBER=1001
USER_1_DEPARTMENT=Oddeleni
USER_1_EMAIL=admin@firma.cz
USER_1_HOURLYFUND=40
